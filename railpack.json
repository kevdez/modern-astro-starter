{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": ["npm install --omit=dev --legacy-peer-deps"]
    },
    "build": {
      "inputs": [{ "step": "install" }],
      "commands": ["npm run build"]
    }
  },
  
  "deploy": {
    "startCommand": "npm run start"
  }
}

